---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">

<!-- ===== NAV ===== -->
<nav class="fixed top-0 w-full z-50 glass-nav" id="mainNav">
  <div class="flex justify-between items-center w-full px-6 md:px-8 py-4 md:py-5">
    <div class="flex items-center gap-8 md:gap-12">
      <a href="#" class="text-xl md:text-2xl font-extrabold tracking-tighter text-primary">Morrigan Black</a>
      <div class="hidden md:flex items-center gap-8 font-headline text-xs tracking-[0.2em] uppercase">
        <a class="text-primary font-bold border-b-2 border-primary pb-1" href="#">Home</a>
        <a class="text-on-surface/60 hover:text-primary transition-colors" href="#backlist">Books</a>
        <a class="text-on-surface/60 hover:text-primary transition-colors" href="#about-section">About</a>
        <a class="text-on-surface/60 hover:text-primary transition-colors" href="#contact-section">Contact</a>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <a href="https://www.youtube.com/@MorriganBlack" target="_blank" rel="noopener noreferrer"
         class="hidden sm:inline-flex items-center gap-2 bg-youtube-red/10 border border-youtube-red/30 text-youtube-red px-5 py-2 rounded-sm text-xs font-bold uppercase tracking-[0.15em] hover:bg-youtube-red/20 transition-all">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">play_circle</span>
        YouTube
      </a>
      <button class="md:hidden text-on-surface/80 hover:text-primary transition-colors p-1" id="mobileToggle" aria-label="Toggle menu">
        <span class="material-symbols-outlined text-2xl" id="menuIcon">menu</span>
      </button>
    </div>
  </div>
  <div class="mobile-menu md:hidden px-6 bg-surface-container-lowest/95 backdrop-blur-xl border-t border-primary/10" id="mobileMenu">
    <div class="flex flex-col gap-4 py-6 font-headline text-sm tracking-[0.15em] uppercase">
      <a class="text-primary font-bold" href="#">Home</a>
      <a class="text-on-surface/60 hover:text-primary transition-colors" href="#backlist">Books</a>
      <a class="text-on-surface/60 hover:text-primary transition-colors" href="#about-section">About</a>
      <a class="text-on-surface/60 hover:text-primary transition-colors" href="#contact-section">Contact</a>
      <a href="https://www.youtube.com/@MorriganBlack" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center justify-center gap-2 bg-youtube-red text-white px-6 py-3 rounded-sm text-xs font-bold uppercase tracking-[0.15em] mt-2">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">play_circle</span>
        YouTube
      </a>
    </div>
  </div>
</nav>

<main>
<!-- ===== HERO ===== -->
<section class="relative h-[92vh] min-h-[650px] w-full overflow-hidden bg-surface-container-lowest">
  <div class="absolute inset-0">
    <img alt="Possessed by the Dreadbringer cover art" class="w-full h-full object-cover"
         src="/images/covers/possessedbythedread_bk4.jpg"/>
    <div class="absolute inset-0 hero-gradient"></div>
  </div>

  <div class="relative h-full flex flex-col justify-end px-6 md:px-16 pb-24 md:pb-32 max-w-7xl mx-auto animate-hero">
    <div class="mb-5 flex items-center gap-4 flex-wrap">
      <span class="px-3 py-1 bg-primary/10 border border-primary/30 text-primary text-[10px] font-bold tracking-[0.2em] rounded-sm uppercase">New Release</span>
      <span class="flex items-center gap-1.5 text-primary text-xs font-bold">
        <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        Offworld Meat Market &mdash; Book 4
      </span>
    </div>

    <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl font-black text-on-surface leading-[0.9] tracking-tighter mb-4 max-w-3xl uppercase">
      Possessed by<br/>the Dreadbringer
    </h1>

    <p class="text-on-surface/70 text-base md:text-lg max-w-xl mb-8 leading-relaxed">
      Ronan spent his entire life running from trouble &mdash; but he can't outrun a soon-to-be god who's already bound himself to his soul.
    </p>

    <div class="flex flex-wrap items-center gap-3 mb-10">
      <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary text-[10px] font-bold tracking-wider rounded-full">Ruthless Hero</span>
      <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary text-[10px] font-bold tracking-wider rounded-full">You Belong to Me</span>
      <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary text-[10px] font-bold tracking-wider rounded-full">I Hate Everyone But You</span>
    </div>

    <div class="flex items-center gap-4 flex-wrap">
      <a href="https://www.amazon.com/dp/B0GY9J28Q9" target="_blank" rel="noopener noreferrer"
         class="bg-primary hover:bg-primary/90 text-on-primary px-8 md:px-10 py-4 rounded-sm font-bold flex items-center gap-2 transition-all active:scale-95 shadow-[0px_10px_30px_rgba(0,229,204,0.3)] text-sm md:text-base">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">menu_book</span>
        Read Now
      </a>
    </div>
  </div>
</section>

<!-- ===== CONTENT AREA ===== -->
<div class="relative -mt-20 z-10 space-y-20 md:space-y-28 pb-24 md:pb-32">

